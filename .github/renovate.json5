{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "group:monorepos",
    "group:recommended",
  ],
  // Repo uses `master`, not `main`.
  baseBranches: ["master"],
  timezone: "Europe/Berlin",
  schedule: ["before 6am on monday"],
  prHourlyLimit: 4,
  prConcurrentLimit: 10,
  // Disabled: on this repo it only churns non-deterministic pnpm peer-dep
  // annotations (e.g. `debug@4.4.3` toggling) with no real version change,
  // producing a stream of empty PRs. Direct dep updates already refresh the
  // lockfile, so maintenance adds noise without value here.
  lockFileMaintenance: {
    enabled: false,
  },
  packageRules: [
    // Internal workspace packages — not published to npm. The Docusaurus
    // template pins a real semver range (^0.0.0) so end-users who copy it
    // resolve from npm; inside the monorepo it's overridden to workspace:*.
    // Without this, Renovate tries to look them up on npm and fails.
    {
      matchPackageNames: ["@ktdocs/**"],
      enabled: false,
    },
    // Manages all four GitHub Actions workflows.
    {
      matchManagers: ["github-actions"],
      groupName: "github-actions",
      // Pin actions to digests for supply-chain safety, but show the tag.
      pinDigests: true,
    },
    // Go modules for the Hugo themes (packages/hugo, templates/hugo).
    {
      matchManagers: ["gomod"],
      groupName: "go modules",
    },
    // Docusaurus stack moves together.
    {
      matchPackageNames: ["@docusaurus/**", "/^@docusaurus//"],
      groupName: "docusaurus",
    },
    // Bundle low-risk dev tooling (lint/format/types) into one PR.
    {
      matchManagers: ["npm"],
      matchDepTypes: ["devDependencies"],
      matchUpdateTypes: ["minor", "patch"],
      groupName: "dev dependencies (non-major)",
    },
    // Auto-merge type-only definition packages.
    {
      matchPackageNames: ["@types/**"],
      automerge: true,
    },
    // The pinned packageManager (pnpm@…) — keep it, but on its own.
    {
      matchDepTypes: ["packageManager"],
      groupName: "packageManager (pnpm)",
    },
  ],
}
