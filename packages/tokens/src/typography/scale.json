{
  "$description": "8-step documentation type scale: display, h1, h2, h3, body, small, caption, code. Each step has size, line-height, weight, tracking. Components consume these only — no arbitrary sizes.",
  "type": {
    "display": {
      "size": { "$type": "dimension", "$value": "44px" },
      "line": { "$type": "number", "$value": 1.1 },
      "weight": { "$type": "fontWeight", "$value": 700 },
      "tracking": { "$type": "dimension", "$value": "-0.025em" }
    },
    "h1": {
      "size": { "$type": "dimension", "$value": "32px" },
      "line": { "$type": "number", "$value": 1.18 },
      "weight": { "$type": "fontWeight", "$value": 700 },
      "tracking": { "$type": "dimension", "$value": "-0.02em" }
    },
    "h2": {
      "size": { "$type": "dimension", "$value": "24px" },
      "line": { "$type": "number", "$value": 1.25 },
      "weight": { "$type": "fontWeight", "$value": 600 },
      "tracking": { "$type": "dimension", "$value": "-0.01em" }
    },
    "h3": {
      "size": { "$type": "dimension", "$value": "18px" },
      "line": { "$type": "number", "$value": 1.35 },
      "weight": { "$type": "fontWeight", "$value": 600 },
      "tracking": { "$type": "dimension", "$value": "-0.005em" }
    },
    "body": {
      "size": { "$type": "dimension", "$value": "16px" },
      "line": { "$type": "number", "$value": 1.6 },
      "weight": { "$type": "fontWeight", "$value": 400 },
      "tracking": { "$type": "dimension", "$value": "0" }
    },
    "small": {
      "size": { "$type": "dimension", "$value": "13.5px" },
      "line": { "$type": "number", "$value": 1.55 },
      "weight": { "$type": "fontWeight", "$value": 400 },
      "tracking": { "$type": "dimension", "$value": "0" }
    },
    "caption": {
      "size": { "$type": "dimension", "$value": "12px" },
      "line": { "$type": "number", "$value": 1.45 },
      "weight": { "$type": "fontWeight", "$value": 400 },
      "tracking": { "$type": "dimension", "$value": "0.05em" }
    },
    "code": {
      "size": { "$type": "dimension", "$value": "13.5px" },
      "line": { "$type": "number", "$value": 1.65 },
      "weight": { "$type": "fontWeight", "$value": 400 },
      "tracking": { "$type": "dimension", "$value": "0" }
    }
  }
}
